#!/usr/bin/env bash
set -euo pipefail

die() {
  printf 'orbit: error: %s\n' "$*" >&2
  exit 1
}

note() {
  printf 'orbit: %s\n' "$*" >&2
}

script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}

BIN_DIR="$(script_dir)"
ORBIT_AGENT_DIR="$(cd "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"
LIB_DIR="$ORBIT_AGENT_DIR/lib"
TEMPLATE_DIR="$ORBIT_AGENT_DIR/templates"

usage() {
  cat <<'USAGE'
Usage:
  orbit init --workspace PATH [--orbit-home PATH] [--codex-home PATH] [--force]
  orbit launch [--dry-run]
  orbit status
  orbit peek researcher|executor|helper
  orbit send executor|helper "message"
  orbit send-file executor|helper /path/to/message.md
  orbit queue executor|helper "message"
  orbit notify researcher --from helper|executor|watcher [--type TYPE] [--severity LEVEL] "message"
  orbit doctor
  orbit role-prompt researcher|executor|helper

Environment:
  ORBIT_HOME       Defaults to ~/.codex/orbit.
  ORBIT_CONFIG     Defaults to $ORBIT_HOME/config.toml.
USAGE
}

default_orbit_home() {
  printf '%s\n' "${ORBIT_HOME:-$HOME/.codex/orbit}"
}

config_path() {
  printf '%s\n' "${ORBIT_CONFIG:-$(default_orbit_home)/config.toml}"
}

toml_get() {
  local key="$1"
  local path="$2"
  [ -r "$path" ] || return 1
  awk -F= -v key="$key" '
    $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
      value=$0
      sub(/^[^=]*=/, "", value)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      if (value ~ /^".*"$/) {
        sub(/^"/, "", value)
        sub(/"$/, "", value)
      }
      print value
      exit
    }
  ' "$path"
}

load_config() {
  local cfg
  local user_orbit_home_set=0
  [ -n "${ORBIT_HOME+x}" ] && user_orbit_home_set=1
  cfg="$(config_path)"
  export ORBIT_HOME="${ORBIT_HOME:-$HOME/.codex/orbit}"
  if [ -r "$cfg" ]; then
    local value
    value="$(toml_get orbit_home "$cfg" || true)"; [ -n "$value" ] && [ "$user_orbit_home_set" = "0" ] && export ORBIT_HOME="$value"
    value="$(toml_get codex_home "$cfg" || true)"; [ -n "$value" ] && [ -z "${CODEX_HOME+x}" ] && export CODEX_HOME="$value"
    value="$(toml_get workspace "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_WORKSPACE+x}" ] && export ORBIT_WORKSPACE="$value"
    value="$(toml_get codex_command "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_CODEX_COMMAND+x}" ] && export ORBIT_CODEX_COMMAND="$value"
    value="$(toml_get researcher_session "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_RESEARCHER_SESSION+x}" ] && export ORBIT_RESEARCHER_SESSION="$value"
    value="$(toml_get executor_session "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_EXECUTOR_SESSION+x}" ] && export ORBIT_EXECUTOR_SESSION="$value"
    value="$(toml_get helper_session "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_HELPER_SESSION+x}" ] && export ORBIT_HELPER_SESSION="$value"
    value="$(toml_get researcher_submit_keys "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_NOTIFY_SUBMIT_KEYS+x}" ] && export ORBIT_NOTIFY_SUBMIT_KEYS="$value"
    value="$(toml_get worker_submit_keys "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_COMM_SUBMIT_KEYS+x}" ] && export ORBIT_COMM_SUBMIT_KEYS="$value"
    value="$(toml_get max_inline_chars "$cfg" || true)"; [ -n "$value" ] && [ -z "${ORBIT_COMM_MAX_INLINE_CHARS+x}" ] && export ORBIT_COMM_MAX_INLINE_CHARS="$value"
  fi
  export ORBIT_COMM_ROOT="${ORBIT_COMM_ROOT:-$ORBIT_HOME/comm}"
}

write_config() {
  local orbit_home="$1"
  local workspace="$2"
  local codex_home="$3"
  local force="$4"
  local cfg="$orbit_home/config.toml"

  mkdir -p "$orbit_home"
  if [ -e "$cfg" ] && [ "$force" != "1" ]; then
    die "$cfg already exists; pass --force to overwrite"
  fi

  cat > "$cfg" <<EOF
# ORBIT reusable Codex multi-agent framework config.
orbit_home = "$orbit_home"
codex_home = "$codex_home"
workspace = "$workspace"
profile = "fixed3"

researcher_session = "researcher"
executor_session = "executor"
helper_session = "helper"

codex_command = "codex"
researcher_submit_keys = "Enter"
worker_submit_keys = "C-m"
max_inline_chars = "900"

claude_review_command = "claude -p --dangerously-skip-permissions --output-format json --model opus --effort max"
EOF
}

copy_templates() {
  local orbit_home="$1"
  mkdir -p "$orbit_home/templates"
  cp -R "$TEMPLATE_DIR/." "$orbit_home/templates/"
}

cmd_init() {
  local workspace="" orbit_home="" codex_home="${CODEX_HOME:-$HOME/.codex}" force=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --workspace) workspace="${2:-}"; shift 2 ;;
      --orbit-home) orbit_home="${2:-}"; shift 2 ;;
      --codex-home) codex_home="${2:-}"; shift 2 ;;
      --force) force=1; shift ;;
      -h|--help) usage; return 0 ;;
      *) die "unknown init argument '$1'" ;;
    esac
  done
  [ -n "$workspace" ] || die "init requires --workspace PATH"
  orbit_home="${orbit_home:-$(default_orbit_home)}"
  workspace="$(cd "$workspace" >/dev/null 2>&1 && pwd)" || die "workspace does not exist: $workspace"
  mkdir -p "$orbit_home"/{comm/inbox/{executor,helper},comm/outbox,state,logs,payloads}
  write_config "$orbit_home" "$workspace" "$codex_home" "$force"
  copy_templates "$orbit_home"
  note "initialized ORBIT_HOME=$orbit_home"
  note "config=$orbit_home/config.toml"
}

cmd_launch() {
  load_config
  local dry_run=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1; shift ;;
      -h|--help) usage; return 0 ;;
      *) die "unknown launch argument '$1'" ;;
    esac
  done
  local workspace="${ORBIT_WORKSPACE:-$PWD}"
  local codex_cmd="${ORBIT_CODEX_COMMAND:-codex}"
  local role session
  for role in researcher executor helper; do
    case "$role" in
      researcher) session="${ORBIT_RESEARCHER_SESSION:-researcher}" ;;
      executor) session="${ORBIT_EXECUTOR_SESSION:-executor}" ;;
      helper) session="${ORBIT_HELPER_SESSION:-helper}" ;;
    esac
    if [ "$dry_run" = "1" ]; then
      printf 'tmux new-session -d -s %q -c %q %q\n' "$session" "$workspace" "$codex_cmd"
      continue
    fi
    if tmux has-session -t "$session" 2>/dev/null; then
      note "session '$session' already exists; leaving it untouched"
    else
      tmux new-session -d -s "$session" -c "$workspace" "$codex_cmd"
      note "started $role session '$session'"
    fi
  done
}

run_comm() {
  load_config
  exec "$LIB_DIR/tmux_comm.sh" "$@"
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'
}

append_outbox() {
  local from="$1"
  local to="$2"
  local type="$3"
  local severity="$4"
  local summary="$5"
  local outbox="$ORBIT_HOME/comm/outbox/${from}_to_${to}.jsonl"
  mkdir -p "$(dirname "$outbox")"
  local ts j_from j_to j_type j_severity j_summary
  ts="$(date -Is)"
  j_from="$(printf '%s' "$from" | json_escape)"
  j_to="$(printf '%s' "$to" | json_escape)"
  j_type="$(printf '%s' "$type" | json_escape)"
  j_severity="$(printf '%s' "$severity" | json_escape)"
  j_summary="$(printf '%s' "$summary" | json_escape)"
  printf '{"timestamp":%s,"from":%s,"to":%s,"type":%s,"severity":%s,"summary":%s}\n' \
    "$(printf '%s' "$ts" | json_escape)" "$j_from" "$j_to" "$j_type" "$j_severity" "$j_summary" >> "$outbox"
  printf '%s\n' "$outbox"
}

cmd_notify() {
  load_config
  local target="${1:-}"
  [ "$target" = "researcher" ] || die "notify currently supports only target 'researcher'"
  shift
  local from="" type="notice" severity="info"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --from) from="${2:-}"; shift 2 ;;
      --type) type="${2:-}"; shift 2 ;;
      --severity) severity="${2:-}"; shift 2 ;;
      --) shift; break ;;
      -*) die "unknown notify option '$1'" ;;
      *) break ;;
    esac
  done
  [ -n "$from" ] || die "notify requires --from helper|executor|watcher"
  [ "$#" -ge 1 ] || die "notify requires a message"
  local message="$*"
  local outbox
  outbox="$(append_outbox "$from" researcher "$type" "$severity" "$message")"
  if "$LIB_DIR/notify_researcher.sh" "[$from -> researcher] $message"; then
    note "notice delivered; outbox=$outbox"
  else
    note "tmux notice failed; durable outbox retained at $outbox"
  fi
}

cmd_doctor() {
  load_config
  local ok=1
  printf 'ORBIT_HOME=%s\n' "$ORBIT_HOME"
  printf 'ORBIT_CONFIG=%s\n' "$(config_path)"
  printf 'WORKSPACE=%s\n' "${ORBIT_WORKSPACE:-}"
  for bin in tmux codex python3; do
    if command -v "$bin" >/dev/null 2>&1; then
      printf 'PASS command %s: %s\n' "$bin" "$(command -v "$bin")"
    else
      printf 'FAIL command %s missing\n' "$bin"
      ok=0
    fi
  done
  if command -v claude >/dev/null 2>&1; then
    printf 'PASS command claude: %s\n' "$(command -v claude)"
  else
    printf 'WARN command claude missing; Claude review will be unavailable\n'
  fi
  for dir in "$ORBIT_HOME" "$ORBIT_HOME/comm/inbox/executor" "$ORBIT_HOME/comm/inbox/helper" "$ORBIT_HOME/comm/outbox"; do
    if [ -d "$dir" ] && [ -w "$dir" ]; then
      printf 'PASS writable dir %s\n' "$dir"
    else
      printf 'FAIL missing or non-writable dir %s\n' "$dir"
      ok=0
    fi
  done
  "$LIB_DIR/tmux_comm.sh" status || true
  if [ -r "$(config_path)" ] && grep -Eq '/HOME/paratera_xy|/XYFS02|/tmp/orbit' "$(config_path)"; then
    printf 'WARN config contains machine-local absolute paths; this is expected for generated per-server config, but do not copy this config between servers\n'
  fi
  [ "$ok" = "1" ] || exit 1
}

cmd_role_prompt() {
  local role="${1:-}"
  case "$role" in
    researcher|executor|helper) ;;
    *) die "role-prompt requires researcher, executor, or helper" ;;
  esac
  cat "$TEMPLATE_DIR/roles/${role}.md"
}

cmd="${1:-}"
case "$cmd" in
  init) shift; cmd_init "$@" ;;
  launch) shift; cmd_launch "$@" ;;
  status) shift; run_comm status "$@" ;;
  peek) shift; run_comm peek "$@" ;;
  send) shift; run_comm send "$@" ;;
  send-file) shift; run_comm send-file "$@" ;;
  queue) shift; run_comm queue "$@" ;;
  notify) shift; cmd_notify "$@" ;;
  doctor) shift; cmd_doctor "$@" ;;
  role-prompt) shift; cmd_role_prompt "$@" ;;
  -h|--help|help|'') usage ;;
  *) usage >&2; die "unknown command '$cmd'" ;;
esac
